{
  "name": "@diplodoc/latex-extension",
  "version": "1.4.1",
  "description": "Extension for Diplodoc platform which adds support for Latex syntax using Katex",
  "main": "build/plugin/index.js",
  "types": "build/plugin/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git@github.com:diplodoc-platform/latex-extension.git"
  },
  "exports": {
    ".": {
      "types": "./build/plugin/index.d.ts",
      "node": "./build/plugin/index-node.js",
      "default": "./build/plugin/index.js"
    },
    "./plugin": {
      "types": "./build/plugin/index.d.ts",
      "node": "./build/plugin/index-node.js",
      "default": "./build/plugin/index.js"
    },
    "./runtime": {
      "types": "./build/runtime/index.d.ts",
      "node": "./build/runtime/index.js",
      "default": "./build/runtime/index-browser.js"
    },
    "./runtime/styles": "./build/runtime/index.css",
    "./react": "./build/react/index.js",
    "./hooks": "./build/react/index.js"
  },
  "typesVersions": {
    "*": {
      "index.d.ts": [
        "./build/plugin/index.d.ts"
      ],
      "plugin": [
        "./build/plugin/index.d.ts"
      ],
      "runtime": [
        "./build/runtime/index.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "run-p build:*",
    "build:js": "node ./esbuild/build.js",
    "build:declarations": "tsc --project tsconfig.publish.json --emitDeclarationOnly --outDir ./build",
    "prepublishOnly": "npm run typecheck && npm run lint && npm test && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "lint",
    "lint:fix": "lint fix",
    "pre-commit": "lint-staged",
    "prepare": "husky || true"
  },
  "author": "",
  "license": "MIT",
  "files": [
    "build"
  ],
  "devDependencies": {
    "@diplodoc/tsconfig": "^1.0.2",
    "@types/katex": "^0.16.7",
    "@types/markdown-it": "^13.0.9",
    "@types/node": "^22.19.7",
    "@types/react": "^18.2.45",
    "@vitest/coverage-v8": "^3.2.4",
    "katex": "^0.16.9",
    "markdown-it": "^13.0.2",
    "npm-run-all": "^4.1.5",
    "react": "^18.2.0",
    "typescript": "^5.3.3",
    "vitest": "^3.2.4",
    "@diplodoc/infra": "2.0.1"
  },
  "peerDependencies": {
    "katex": "^0.16.9",
    "markdown-it": "^13.0.0",
    "react": "^16.14.0 || ^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
